// Duedilis — Prisma Schema v0
// Módulos 1-3: Auth+Users+Orgs+Projects+Memberships | RBAC+ACL | Issues+Evidence+Comments+Stamps+Close
// Task: gov-1774993595452-4lllx0
// Data: 2026-03-31
// ORM: Prisma
// DB: PostgreSQL (Neon serverless)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// MÓDULO 1: AUTH + UTILIZADORES + ORGANIZAÇÕES + PROJETOS + MEMBERSHIPS
// ============================================================

// Auth.js v5 required tables

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?   // Null for OAuth-only users
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Auth.js relations
  accounts Account[]
  sessions Session[]

  // Memberships
  orgMemberships     OrgMembership[]
  projectMemberships ProjectMembership[]

  // Activity
  createdIssues  Issue[]        @relation("IssueReporter")
  assignedIssues Issue[]        @relation("IssueAssignee")
  issueComments  IssueComment[]
  issueStamps    IssueStamp[]
  issueClosure   IssueClosure[]
  evidences      Evidence[]
  folderAcls     FolderAcl[]
  auditLogs      AuditLog[]
  documents      Document[]
  uploadBatches  UploadBatch[]
}

// Organization = tenant root
model Organization {
  id          String   @id @default(cuid())
  slug        String   @unique // URL-friendly identifier
  name        String
  description String?
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships   OrgMembership[]
  projects      Project[]
  cdeFolders    CdeFolder[]
  issues        Issue[]
  auditLogs     AuditLog[]
  stamps        Stamp[]
  documents     Document[]
  uploadBatches UploadBatch[]
}

model OrgMembership {
  id        String   @id @default(cuid())
  userId    String
  orgId     String
  role      OrgRole  @default(OBSERVADOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId])
  @@index([userId])
}

model Project {
  id          String        @id @default(cuid())
  orgId       String
  name        String
  slug        String        // Unique within org
  description String?
  address     String?       // Localização da obra
  status      ProjectStatus @default(ATIVO)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  org           Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  memberships   ProjectMembership[]
  issues        Issue[]
  cdeFolders    CdeFolder[]
  documents     Document[]
  uploadBatches UploadBatch[]

  @@unique([orgId, slug])
  @@index([orgId])
}

model ProjectMembership {
  id        String      @id @default(cuid())
  userId    String
  projectId String
  orgId     String      // Denormalised for RLS efficiency
  role      ProjectRole @default(OBSERVADOR)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
  @@index([userId])
  @@index([orgId])
}

// ============================================================
// MÓDULO 2: RBAC E ACL POR PASTA CDE
// ============================================================

// CDE = Common Data Environment (ISO 19650 inspired)
// Pastas hierárquicas dentro de um projeto
model CdeFolder {
  id          String   @id @default(cuid())
  orgId       String   // Multi-tenant: always filter by orgId
  projectId   String
  name        String
  description String?
  parentId    String?  // Null = root folder
  path        String   // Materialised path: /orgId/projectId/parent/.../id
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent    CdeFolder?   @relation("FolderTree", fields: [parentId], references: [id])
  children  CdeFolder[]  @relation("FolderTree")
  acls      FolderAcl[]
  documents Document[]

  @@index([orgId])
  @@index([projectId])
  @@index([parentId])
}

// ACL granular por pasta: definir permissões a utilizadores ou roles
model FolderAcl {
  id          String       @id @default(cuid())
  orgId       String
  folderId    String
  userId      String?      // Null = aplica a todos com o role especificado
  role        ProjectRole? // Null = utilizador específico (userId must be set)
  permissions FolderPerm[] // Array de permissões concedidas
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  folder CdeFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  user   User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([folderId])
  @@index([orgId])
  @@index([userId])
}

// ============================================================
// MÓDULO 3: ISSUES + EVIDÊNCIAS + COMENTÁRIOS + STAMPS + FECHO
// ============================================================

model Issue {
  id           String      @id @default(cuid())
  orgId        String      // Multi-tenant
  projectId    String
  type         IssueType
  title        String
  description  String?     @db.Text
  status       IssueStatus @default(ABERTA)
  priority     Priority    @default(MEDIA)
  reportedById String
  assigneeId   String?
  dueDate      DateTime?
  location     String?     // Localização na obra (zona, piso, etc.)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project  Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reporter User         @relation("IssueReporter", fields: [reportedById], references: [id])
  assignee User?        @relation("IssueAssignee", fields: [assigneeId], references: [id])

  evidence Evidence[]
  comments IssueComment[]
  stamps   IssueStamp[]
  closure  IssueClosure?

  @@index([orgId])
  @@index([projectId])
  @@index([status])
  @@index([assigneeId])
  @@index([type])
}

// Evidências: fotos ou documentos associados a uma issue
model Evidence {
  id            String       @id @default(cuid())
  orgId         String       // Multi-tenant
  issueId       String
  type          EvidenceType
  fileName      String
  fileUrl       String       // R2 presigned base path
  fileHash      String       // SHA-256 for integrity
  fileSizeBytes Int
  mimeType      String
  // Metadata: GPS, camera info, etc. (stored as JSON)
  metadata      Json?
  caption       String?
  uploadedById  String
  createdAt     DateTime     @default(now())

  issue      Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  uploadedBy User  @relation(fields: [uploadedById], references: [id])

  @@index([issueId])
  @@index([orgId])
}

// Comentários imutáveis: sem updatedAt (append-only)
model IssueComment {
  id        String   @id @default(cuid())
  orgId     String   // Multi-tenant
  issueId   String
  content   String   @db.Text
  authorId  String
  createdAt DateTime @default(now())
  // No updatedAt — comments are immutable after creation

  issue  Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id])

  @@index([issueId])
  @@index([orgId])
}

// Stamps: registo imutável de cada transição de estado numa issue
model IssueStamp {
  id         String      @id @default(cuid())
  orgId      String
  issueId    String
  fromStatus IssueStatus
  toStatus   IssueStatus
  userId     String
  note       String?
  hash       String      // SHA-256(issueId+fromStatus+toStatus+userId+createdAt)
  createdAt  DateTime    @default(now())
  // No updatedAt — stamps are immutable

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@index([issueId])
  @@index([orgId])
}

// Fecho formal da issue: quem fechou, quando, sob que condições
model IssueClosure {
  id          String   @id @default(cuid())
  orgId       String
  issueId     String   @unique // One closure per issue
  closedById  String
  conditions  String   @db.Text // Condições de fecho (texto formal)
  attachments Json?    // Lista de evidências referenciadas no fecho
  verifiedAt  DateTime @default(now())

  issue    Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  closedBy User  @relation(fields: [closedById], references: [id])

  @@index([orgId])
}

// ============================================================
// MÓDULO 4: CDE DOCUMENTOS + UPLOAD EM LOTE
// ============================================================

// UploadBatch: agrupa N ficheiros num upload em lote
model UploadBatch {
  id             String      @id @default(cuid())
  orgId          String
  projectId      String
  folderId       String
  uploadedById   String
  totalFiles     Int
  processedFiles Int         @default(0)
  status         BatchStatus @default(UPLOADING)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project  Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploader User         @relation(fields: [uploadedById], references: [id])
  documents Document[]

  @@index([orgId])
  @@index([uploadedById])
  @@index([status])
}

// Document: ficheiro no CDE com normalização ISO 19650
model Document {
  id        String  @id @default(cuid())
  orgId     String  // Multi-tenant: sempre filtrar por orgId
  projectId String
  folderId  String
  batchId   String? // Link ao UploadBatch (null se upload individual)

  // Nomenclatura
  originalName String  // Nome original do ficheiro — preservado sempre
  isoName      String? // Nome ISO 19650 sugerido/confirmado (opcional)
  discipline   String? // Código de disciplina ISO 19650 (AR, ST, ME, EL, PL, GE, SS, FP)
  docType      String? // Tipo de documento ISO 19650 (DR, SP, RP, CA, PR, MS, RFI, CO)
  revision     String? // Revisão ISO 19650 (A, B, C, P01, P02, C01, C02...)

  // Storage
  storageKey    String // R2 key: /{orgId}/{projectId}/{folderId}/{docId}/{filename}
  fileHash      String // SHA-256 calculado no client antes do upload, verificado pelo servidor
  fileSizeBytes Int
  mimeType      String

  // Estado do pipeline de upload
  status DocumentStatus @default(PENDING)

  // Relações
  uploadedById String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project  Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder   CdeFolder    @relation(fields: [folderId], references: [id], onDelete: Cascade)
  uploader User         @relation(fields: [uploadedById], references: [id])
  batch    UploadBatch? @relation(fields: [batchId], references: [id])

  @@index([orgId])
  @@index([projectId])
  @@index([folderId])
  @@index([batchId])
  @@index([status])
}

// ============================================================
// AUDIT TRAIL + STAMPS GENÉRICOS
// ============================================================

// Audit log imutável com hash encadeado
model AuditLog {
  id         String   @id @default(cuid())
  orgId      String
  entityType String   // "Issue", "Evidence", "Document", etc.
  entityId   String
  action     String   // "CREATE", "UPDATE", "DELETE", "TRANSITION"
  userId     String
  payload    Json?    // Snapshot do estado após a acção
  prevHash   String?  // Hash do registo anterior (null para o primeiro)
  hash       String   // SHA-256(prevHash+entityType+entityId+action+userId+payload+createdAt)
  createdAt  DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id])

  @@index([orgId])
  @@index([entityType, entityId])
  @@index([userId])
}

// Stamps genéricos (reutilizados por módulos futuros: Document, Approval, etc.)
model Stamp {
  id         String   @id @default(cuid())
  orgId      String
  entityType String   // "Issue", "Document", "Approval"
  entityId   String
  fromState  String
  toState    String
  userId     String
  note       String?
  hash       String   // SHA-256(entityType+entityId+fromState+toState+userId+createdAt)
  createdAt  DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([entityType, entityId])
}

// ============================================================
// ENUMS
// ============================================================

enum OrgRole {
  ADMIN_ORG
  GESTOR_PROJETO
  FISCAL
  TECNICO
  AUDITOR
  OBSERVADOR
}

enum ProjectRole {
  ADMIN_ORG // Herda da org
  GESTOR_PROJETO
  FISCAL
  TECNICO
  AUDITOR
  OBSERVADOR
}

enum FolderPerm {
  READ
  WRITE
  APPROVE
  DELETE
  MANAGE_ACL
}

enum ProjectStatus {
  ATIVO
  SUSPENSO
  CONCLUIDO
  CANCELADO
}

enum IssueType {
  NAO_CONFORMIDADE
  RFI // Request for Information
  RISCO
  OBSERVACAO
}

enum IssueStatus {
  ABERTA
  EM_ANALISE
  ACAO_CORRECTIVA
  VERIFICACAO
  FECHADA
}

enum Priority {
  CRITICA
  ALTA
  MEDIA
  BAIXA
}

enum EvidenceType {
  FOTO
  DOCUMENTO
  VIDEO
  OUTRO
}

enum DocumentStatus {
  PENDING // Ficheiro recebido no R2, aguarda normalização IA
  NORMALIZING // Claude Haiku a processar nome ISO 19650
  READY // Normalização concluída, aguarda revisão do utilizador
  CONFIRMED // Utilizador confirmou nome — documento activo no CDE
  REJECTED // Utilizador rejeitou — registo mantido mas inacessível
}

enum BatchStatus {
  UPLOADING // Uploads R2 a decorrer (presigned URLs activas)
  NORMALIZING // IA a processar todos os ficheiros do batch
  READY // Todos os ficheiros prontos para revisão do utilizador
  CONFIRMED // Utilizador confirmou o batch completo
  PARTIAL // Batch parcialmente confirmado (alguns documentos rejeitados)
}
