# Database (Neon PostgreSQL)
# Pooled connection — use for most queries (Prisma client)
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/duedilis?sslmode=require&pgbouncer=true"

# Direct connection — use for migrations (prisma migrate)
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/duedilis?sslmode=require"

# NextAuth.js
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Cloudflare R2 (upload pipeline D2)
# Cloudflare account ID — visible in Workers & Pages > Overview
R2_ACCOUNT_ID="your-cloudflare-account-id"
# R2 API token with Object Read & Write permissions
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
# Name of the R2 bucket to store uploaded documents
R2_BUCKET_NAME="duedilis-documents"

# Anthropic AI (ISO 19650 normalization — D2-04)
# Used by Claude Haiku to suggest ISO 19650-compliant document names
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-your-api-key-here"
