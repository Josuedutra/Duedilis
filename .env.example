# Database (Neon PostgreSQL)
# Pooled connection — use for most queries (Prisma client)
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/duedilis?sslmode=require&pgbouncer=true"

# Direct connection — use for migrations (prisma migrate)
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/duedilis?sslmode=require"

# NextAuth.js
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
